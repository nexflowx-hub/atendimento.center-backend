# TLS / Caddy
ACME_EMAIL=ops@atlasglobal.digital
EVOLUTION_BASIC_AUTH_HASH=

# Pinned application versions
CHATWOOT_VERSION=v4.16.0-ce

# Local infrastructure (Chatwoot + Evolution only)
LOCAL_POSTGRES_USER=atendimento
LOCAL_POSTGRES_PASSWORD=
REDIS_PASSWORD=
CHATWOOT_SECRET_KEY_BASE=
EVOLUTION_API_KEY=

# Atendimento.Center application database in Supabase
SUPABASE_DATABASE_URL=postgresql://postgres.PROJECT_REF:URL_ENCODED_PASSWORD@aws-1-us-west-2.pooler.supabase.com:5432/postgres?sslmode=require

# Filled after creating the Chatwoot admin/API token
CHATWOOT_API_TOKEN=

# AI provider
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4.1-mini

# Optional SMTP
MAILER_SENDER_EMAIL=Atendimento.Center <no-reply@atendimento.center>
SMTP_ADDRESS=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_AUTHENTICATION=login
SMTP_ENABLE_STARTTLS_AUTO=true
